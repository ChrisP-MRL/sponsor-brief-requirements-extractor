        <mxCell id="legend_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="260" width="1600" x="100" y="1900" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=1;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;VELS WORKFLOW PATTERN APPLIED - KEY CHANGES&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="1600" x="100" y="1910" as="geometry" />
        </mxCell>
        <mxCell id="leg_vels" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;verticalAlign=top;" value="&lt;b&gt;1. VELS THREE-STATE PATTERN (APPLIED TO ALL STAGES):&lt;/b&gt;&lt;br&gt;• UNCOMMITTED (Blue boxes) - Data is editable, parties can flag issues, request corrections, add comments&lt;br&gt;• COMMITTED (Red circles) - Data becomes immutable official record after all parties sign&lt;br&gt;• PUBLISHED (Green boxes) - Committed data distributed to ShareFile, VELS Event Hub, downstream systems" vertex="1">
          <mxGeometry height="60" width="760" x="120" y="1937" as="geometry" />
        </mxCell>
        <mxCell id="leg_qa" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;verticalAlign=top;" value="&lt;b&gt;2. SURVEY COORDINATOR QA ROLE (NEW):&lt;/b&gt;&lt;br&gt;• Marine Supervisor / Survey Coordinator acts as QA gate (orange boxes)&lt;br&gt;• Reviews data quality before commitment&lt;br&gt;• Coordinates multi-party approval process&lt;br&gt;• Mirrors Marine Supervisor role in VELS daily QA (05:30 AWST)" vertex="1">
          <mxGeometry height="60" width="760" x="120" y="2007" as="geometry" />
        </mxCell>
        <mxCell id="leg_edit" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;verticalAlign=top;" value="&lt;b&gt;3. REAL-TIME EDITING WINDOW:&lt;/b&gt;&lt;br&gt;• All parties can edit/comment during UNCOMMITTED phase&lt;br&gt;• Data only becomes immutable after commitment gate&lt;br&gt;• Dispute resolution keeps data UNCOMMITTED until resolved" vertex="1">
          <mxGeometry height="40" width="760" x="120" y="2077" as="geometry" />
        </mxCell>
        <mxCell id="leg_blocking" parent="1" style="text;html=1;strokeColor=#C62828;fillColor=#FFEBEE;align=left;fontSize=10;verticalAlign=top;" value="&lt;b&gt;4. BLOCKING DEPENDENCIES:&lt;/b&gt;&lt;br&gt;• Stage 1 COMMITTED → Cargo transfer can begin&lt;br&gt;• Stage 3 COMMITTED + VELS COMMITTED TSV data → Reconciliation&lt;br&gt;• Stage 4 COMMITTED → Bill of Lading &amp;amp; Publication&lt;br&gt;• Missing any party during QA approval → BLOCKS commitment&lt;br&gt;• Variance &amp;gt;±0.5% → Forces dispute resolution (stays UNCOMMITTED)" vertex="1">
          <mxGeometry height="80" width="740" x="920" y="1950" as="geometry" />
        </mxCell>
        <mxCell id="leg_pub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;verticalAlign=top;" value="&lt;b&gt;5. PUBLICATION SEPARATION:&lt;/b&gt;&lt;br&gt;• Commitment creates immutable record FIRST&lt;br&gt;• Publication distributes to multiple systems AFTER commitment&lt;br&gt;• ShareFile (Legal P&amp;I evidence) | VELS Event Hub (Operational) | Downstream (Ampla, Databricks)&lt;br&gt;• Only COMMITTED data can be published - prevents premature distribution" vertex="1">
          <mxGeometry height="60" width="740" x="920" y="2035" as="geometry" />
        </mxCell>
        <mxCell id="leg_critical" parent="1" style="text;html=1;strokeColor=#2E7D32;fillColor=#E8F5E9;align=left;fontSize=9;verticalAlign=top;" value="&lt;b&gt;6. CRITICAL PATH:&lt;/b&gt; Stage 1 (2-3 hrs) → Cargo Transfer (2-3 days - BOTTLENECK) → Stage 3 (2-3 hrs) → Reconciliation (2-4 hrs) → Documentation (1-2 hrs)" vertex="1">
          <mxGeometry height="20" width="740" x="920" y="2110" as="geometry" />
        </mxCell>
        <mxCell id="s1_witness" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;fontStyle=1;" value="&lt;b&gt;ALL PARTIES WITNESS&lt;/b&gt;&lt;br&gt;Charterer Rep + MRL Rep + Surveyor&lt;br&gt;physically present during survey" vertex="1">
          <mxGeometry height="50" width="480" x="180" y="250" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
